      },
      {
        "ayah_number": 3,
        "text_uthmani": "إِلَـٰهِ ٱلنَّاسِ",
        "translation_en": "The God of mankind,",
        "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/6286.mp3"
      },
      {
        "ayah_number": 4,
        "text_uthmani": "مِن شَرِّ ٱلْوَسْوَاسِ ٱلْخَنَّاسِ",
        "translation_en": "From the evil of the retreating whisperer",
        "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/6287.mp3"
      },
      {
        "ayah_number": 5,
        "text_uthmani": "ٱلَّذِى يُوَسْوِسُ فِى صُدُورِ ٱلنَّاسِ",
        "translation_en": "Who whispers [evil] into the breasts of mankind -",
        "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/6288.mp3"
      },
      {
        "ayah_number": 6,
        "text_uthmani": "مِنَ ٱلْجِنَّةِ وَٱلنَّاسِ",
        "translation_en": "From among the jinn and mankind.\"",
        "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/6289.mp3"
      }
    ]
  }
]
